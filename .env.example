# Copy to .env and edit. Every value is optional — defaults run the demo locally.

# ---- Self-hosted LLM (Ollama) ----
OLLAMA_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b        # bump to qwen2.5:7b or llama3.1:8b on a 16GB+ GPU
EMBED_MODEL=bge-m3

# ---- Connect to the real Hubmicroo website (leave blank for demo data) ----
# Option 1: your site has a search endpoint that takes ?q= and returns products
STORE_SEARCH_URL=
# Option 2: your site exposes the full catalogue as JSON
STORE_CATALOGUE_URL=
STORE_API_KEY=

# If your product JSON uses different key names, map them here:
# FIELD_NAME=title
# FIELD_PRICE=sale_price
# FIELD_STOCK=available
# FIELD_IMAGE=thumbnail
# FIELD_URL=permalink

# ---- Tuning ----
TOP_K=5
DEFAULT_CURRENCY=PKR
