# ─────────────────────────────────────────────────────────────────────────────
# Hubmicroo Voice Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM ───────────────────────────────────────────────────────────────────────
# Ollama model tag. Change to swap models (e.g. llama3.2:3b, phi3:mini).
# Re-run the eval harness after swapping: python eval/run_eval.py
LLM_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://ollama:11434     # use http://localhost:11434 outside Docker
LLM_TEMPERATURE=0.1
LLM_NUM_PREDICT=512
LLM_THINK=false                         # keep false for fast/non-thinking mode

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cpu                        # set to "cuda" on GPU hosts

# ── Vector store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333           # use http://localhost:6333 outside Docker
QDRANT_COLLECTION=hubmicroo

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
BM25_WEIGHT=0.3
DENSE_WEIGHT=0.7
PRODUCT_FLOOR=0.55                      # min fused score to show a product card
MAX_PRODUCT_CARDS=3

# ── Semantic cache ────────────────────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_MAX_SIZE=500

# ── Voice ─────────────────────────────────────────────────────────────────────
WHISPER_MODEL=base                      # tiny | base | small | medium
WHISPER_DEVICE=cpu
PIPER_VOICES_DIR=/app/piper_voices
PIPER_VOICE_EN=en_US-lessac-medium
PIPER_VOICE_UR=ur_PK-usman-medium
PIPER_VOICE_AR=ar_JO-kareem-low
TTS_ENABLED=true

# ── Admin / Auth ──────────────────────────────────────────────────────────────
# CHANGE THESE IN PRODUCTION
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
SECRET_KEY=change-this-secret-key-in-production-minimum-32-chars
JWT_EXPIRE_MINUTES=60

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*                          # production: https://yourdomain.com
HOST=0.0.0.0
PORT=8000

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
PRODUCTS_FILE=/app/data/products.json
PAGES_FILE=/app/data/pages.json

# ── Greetings (customise per store) ──────────────────────────────────────────
GREETING_EN=Hi! I'm the Hubmicroo shopping assistant. How can I help you today?
GREETING_UR=Salam! Main Hubmicroo ka shopping assistant hoon. Aap ki kya madad kar sakta hoon?
GREETING_AR=مرحباً! أنا مساعد تسوق هبمايكرو. كيف يمكنني مساعدتك؟
FALLBACK_EN=I couldn't find what you're looking for. Would you like to contact our support team?
FALLBACK_UR=Mujhe yeh nahi mila. Kya aap hamare support team se baat karna chahenge?
FALLBACK_AR=لم أتمكن من العثور على ما تبحث عنه. هل تريد التواصل مع فريق الدعم؟
